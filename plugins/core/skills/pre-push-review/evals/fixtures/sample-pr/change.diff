+const { sendResetEmail } = require('../lib/mailer');
+const { findUserByEmail } = require('../lib/users');
+const { hourlyCount } = require('../lib/rate-limit');
+
+// RESET-142: rate-limit password-reset requests.
+const RESET_LIMIT_PER_HOUR = 10;
+
+async function requestPasswordReset(req, res) {
+  const email = req.body.email;
+  const user = await findUserByEmail(email);
+
+  if (user) {
+    const key = `pwreset:${email}`;
+    const n = await hourlyCount(key);
+    if (n > RESET_LIMIT_PER_HOUR) {
+      res.status(429).json({ error: 'Too many requests, try again later' });
+    }
+    await sendResetEmail(user);
+  }
+
+  return res.status(200).json({ ok: true });
+}
+
+// RESET-142 follow-up: also throttle logins while we're in here.
+async function throttledLogin(req, res, next) {
+  const key = `login:${req.body.email}`;
+  const n = await hourlyCount(key);
+  if (n > RESET_LIMIT_PER_HOUR) {
+    return res.status(429).json({ error: 'Too many login attempts' });
+  }
+  return next();
+}
+
+module.exports = { requestPasswordReset, throttledLogin };
