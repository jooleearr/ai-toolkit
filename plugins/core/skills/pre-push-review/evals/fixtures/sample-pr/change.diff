+const { requestPasswordReset } = require('../src/controllers/password-reset');
+
+function mockRes() {
+  return {
+    statusCode: 200,
+    body: null,
+    status(c) { this.statusCode = c; return this; },
+    json(b) { this.body = b; return this; },
+  };
+}
+
+test('known user under the limit gets a 200', async () => {
+  const res = mockRes();
+  await requestPasswordReset({ body: { email: 'alice@x.com' } }, res);
+  expect(res.statusCode).toBe(200);
+});
+
+test('known user over the limit gets a 429', async () => {
+  const res = mockRes();
+  for (let i = 0; i < 11; i++) {
+    await requestPasswordReset({ body: { email: 'bob@x.com' } }, res);
+  }
+  expect(res.statusCode).toBe(429);
+});
