-module.exports = { sloppyEqual };
+// Increment an hourly counter and return the new count. The first hit in a
+// window sets the TTL so the window closes an hour later.
+async function hourlyCount(key) {
+  const n = await redisClient.incr(key);
+  if (n === 1) {
+    await redisClient.expire(key, 3600);
+  }
+  return n;
+}
+
+module.exports = { sloppyEqual, hourlyCount };
